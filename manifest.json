{
  "manifest_version": 3,
  "name": "Phishing Guard",
  "description": "Offline fake site detect ",
  "version": "1.0",

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "icons": {
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["rules/blacklist.json", "warning.html"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}


